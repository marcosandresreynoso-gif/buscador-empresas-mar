# Variables de entorno — Buscador de Empresas M-AR
# Cargalas en Render: Dashboard > tu servicio > Environment

# --- Groq (al menos una, podés poner hasta 4 para rotar y no quedarte sin cuota) ---
GROQ_API_KEY=tu_primera_clave_de_groq
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# --- Google Maps (opcional: si no la cargás, usa siempre IA en vez de datos reales) ---
GOOGLE_MAPS_API_KEY=

# --- Node ---
NODE_VERSION=22.16.0
